# Biwenger credentials
BIWENGER_EMAIL=your@email.com
BIWENGER_PASSWORD=yourpassword
BIWENGER_LEAGUE_ID=1809775
BIWENGER_USER_ID=11444346
BIWENGER_ACCOUNT_ID=4019960
BIWENGER_COMPETITION=la-liga
BIWENGER_SCORE_ID=2

# Telegram — get chat_id by running: python scripts/setup_chat_id.py
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=@yourusername_or_numeric_id

# Bot behaviour
DRY_RUN=true                         # Set to false for live actions
MAX_SPEND_PER_JORNADA=5000000        # Max € to spend per jornada cycle
MIN_SQUAD_SIZE=15                    # Never sell below this squad size
CONFIRMATION_TIMEOUT_SECONDS=1800   # 30 min to confirm via Telegram
SSL_VERIFY=false                     # Disable on corporate networks
